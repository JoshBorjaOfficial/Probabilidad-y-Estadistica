#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define Max_Muestras 200
#define Minimo 150
#define Maximo 1300

int main(){
    srand(time(NULL));
    // Rango total para la generación
    int rango = Maximo - Minimo + 1;
    for(int i = 0; i < Max_Muestras; i++){
        // Generamos un entero entre Minimo y Maximo
        int aleatorio = Minimo + (rand() % rango);
        // Imprimimos el entero seguido de un espacio
        printf("[%d] ", aleatorio);
        // Salto de línea cada 10 datos para orden visual
        if((i + 1) % 10 == 0){
            printf("\n");
        }
    }
    return 0;
}
