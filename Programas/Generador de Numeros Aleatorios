#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define Max_Muestras 200
#define Minimo 1
#define Maximo 999

int main(){
    srand(time(NULL));
    for(int i = 0; i < Max_Muestras; i++){
        float escala = (float) rand() / (float) RAND_MAX;
        float aleatorio = Maximo - (escala * (Maximo - Minimo));
        printf("[%.3f] ", aleatorio);

        if((i + 1) % 10 == 0){
            printf("\n");
        }
    }
    return 0;
}
