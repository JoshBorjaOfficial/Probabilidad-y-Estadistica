#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <math.h>

/* Definición de constantes para el control de la muestra y el entorno de simulación */
#define Max_Datos 200      // Tamaño de la muestra (n)
#define Minimo 150         // Límite inferior de latencia en microsegundos
#define Maximo 1300        // Límite superior de latencia en microsegundos
#define Max_Percentil 100  // Capacidad máxima de almacenamiento de percentiles

/* --- MÓDULOS DE ORDENAMIENTO DE DATOS (ALGORITMO QUICKSORT) --- */

/**
 * Intercambia los valores de dos direcciones de memoria.
 * Utilizado para la reestructuración de la muestra durante el ordenamiento.
 */
void Intercambio(float *a, float *b) {
    float Temp = *a;
    *a = *b;
    *b = Temp;
}

/**
 * Define el pivote y particiona el arreglo de datos.
 * Utiliza la técnica de "Mediana de tres" para optimizar el rendimiento del algoritmo.
 */
int Particion(float arr[], int menor, int mayor) {
    int centro = menor + (mayor - menor) / 2;
    // Ordenamiento preventivo de extremos y centro para selección de pivote
    if (arr[menor] > arr[centro]) Intercambio(&arr[menor], &arr[centro]);
    if (arr[menor] > arr[mayor]) Intercambio(&arr[menor], &arr[mayor]);
    if (arr[centro] > arr[mayor]) Intercambio(&arr[centro], &arr[mayor]);

    Intercambio(&arr[centro], &arr[mayor]); // Posicionamiento del pivote
    float pivote = arr[mayor];
    int i = (menor - 1);

    // Reordenamiento de elementos respecto al valor del pivote
    for (int j = menor; j < mayor; j++) {
        if (arr[j] < pivote) {
            i++;
            Intercambio(&arr[i], &arr[j]);
        }
    }
    Intercambio(&arr[i + 1], &arr[mayor]);
    return (i + 1);
}

/**
 * Implementación recursiva del algoritmo QuickSort.
 * Complejidad promedio: O(n log n).
 */
void Quick_Sort(float arr[], int menor, int mayor) {
    if (menor < mayor) {
        int idx_pivote = Particion(arr, menor, mayor);
        Quick_Sort(arr, menor, idx_pivote - 1); // Sub-arreglo izquierdo
        Quick_Sort(arr, idx_pivote + 1, mayor); // Sub-arreglo derecho
    }
}

int main() {
    /* Declaración de variables principales y estructuras de datos */
    float datos[Max_Datos];
    int n = Max_Datos; 
    float suma = 0;
    char unidad[] = "us"; 

    /* Fase de Generación de Muestra Aleatoria */
    srand(time(NULL)); // Inicialización de semilla para aleatoriedad real
    int rango = Maximo - Minimo + 1;

    printf("--- GENERANDO DATOS DE RENDIMIENTO (SHADERS) ---\n");
    for(int i = 0; i < n; i++) {
        int valor_aleatorio = Minimo + (rand() % rango);
        datos[i] = (float)valor_aleatorio;
        suma += datos[i]; // Acumulación para cálculo de media
        printf("[%d] ", valor_aleatorio);
        if((i + 1) % 10 == 0) printf("\n"); // Formato de visualización de 10 columnas
    }

    /* Interacción con el usuario: Configuración de Medidas de Posición (Percentiles) */
    float percentil_buscado[Max_Percentil];
    int num_percentiles;
    printf("\n¿Cuantos percentiles desea calcular? ");
    scanf("%d", &num_percentiles);

    for(int i = 0; i < num_percentiles; i++) {
        printf("Ingrese el valor del percentil [%d]: ", i + 1);
        scanf("%f", &percentil_buscado[i]);
    }

    /* Ejecución del ordenamiento para permitir cálculos de mediana, moda y percentiles */
    Quick_Sort(datos, 0, n - 1);

    printf("\nDatos ordenados:\n");
    for(int i = 0; i < n; i++) {
        printf("%.2f ", datos[i]);
        if((i + 1) % 10 == 0) printf("\n");
    }

    /* --- ANÁLISIS DE DISPERSIÓN: TABLA DE VARIANZA --- */
    float Media_Muestral = suma / n;
    float suma_diferencias = 0;
    float suma_cuadrados = 0;

    printf("\nTabla de Varianza Muestral\n");
    printf("------------------------------------------------------------\n");
    printf("|      xi      |      xi - x      |       (xi - x)^2       |\n");
    printf("------------------------------------------------------------\n");
    
    for(int i = 0; i < n; i++) {
        float diferencia = datos[i] - Media_Muestral; // Desviación respecto a la media
        float dif_cuadrado = diferencia * diferencia; // Desviación al cuadrado
        suma_diferencias += diferencia; // Propiedad: La suma de desviaciones debe aproximarse a cero
        suma_cuadrados += dif_cuadrado; // Numerador de la varianza

        // Visualización resumida (Primeros 10 y últimos 10 datos)
        if(i < 10 || i > n - 11) {
            printf("| %12.2f | %16.2f | %22.2f |\n", datos[i], diferencia, dif_cuadrado);
        } else if (i == 10) {
            printf("|      ...     |        ...       |           ...          |\n");
        }
    }
    printf("------------------------------------------------------------\n");
    printf("| SUMA TOTAL   | %13.2f %s | %18.2f %s^2 |\n", suma_diferencias, unidad, suma_cuadrados, unidad);
    printf("------------------------------------------------------------\n");

    /* --- ANÁLISIS DE TENDENCIA CENTRAL: MODA --- */
    int max_frecuencia = 1, frecuencia_actual = 1;
    float modas_detectadas[Max_Datos]; 
    int conteo_modas = 0;
    int hay_moda = 0;

    // Identificación de la frecuencia máxima en la muestra ordenada
    for (int i = 1; i < n; i++) {
        if (datos[i] == datos[i - 1]) frecuencia_actual++;
        else {
            if (frecuencia_actual > max_frecuencia) max_frecuencia = frecuencia_actual;
            frecuencia_actual = 1;
        }
    }
    if (frecuencia_actual > max_frecuencia) max_frecuencia = frecuencia_actual;

    // Registro de valores que cumplen con la frecuencia máxima (detección multimodal)
    if (max_frecuencia > 1) {
        hay_moda = 1;
        frecuencia_actual = 1;
        for (int i = 1; i <= n; i++) {
            if (i < n && datos[i] == datos[i - 1]) {
                frecuencia_actual++;
            } else {
                if (frecuencia_actual == max_frecuencia) {
                    modas_detectadas[conteo_modas] = datos[i - 1];
                    conteo_modas++;
                }
                frecuencia_actual = 1;
            }
        }
    }

    /* --- CÁLCULO E IMPRESIÓN DE MEDIDAS DESCRIPTIVAS --- */
    printf("\n--- RESULTADOS ESTADISTICOS ---");
    
    // Cálculo de percentiles mediante interpolación lineal
    for(int i = 0; i < num_percentiles; i++) {
        float L = (percentil_buscado[i] / 100.0) * (n + 1); // Posición teórica
        int pos = (int)L;
        float f = L - pos; // Fracción decimal para ajuste de valor
        float v_p = (pos < 1) ? datos[0] : (pos >= n) ? datos[n-1] : datos[pos-1] + f * (datos[pos] - datos[pos-1]);
        printf("\nPercentil %.0f (Posicion: %.2f) = Valor: %.2f %s", percentil_buscado[i], L, v_p, unidad);
    }

    printf("\n\nMedia Muestral: %.2f %s", Media_Muestral, unidad);
    printf("\nVarianza Muestral (n-1): %.2f %s^2", suma_cuadrados / (n - 1), unidad);
    printf("\nDesviacion Estandar: %.2f %s", sqrt(suma_cuadrados / (n - 1)), unidad);
    printf("\nMediana: %.2f %s", (n % 2 == 0) ? (datos[n/2 - 1] + datos[n/2]) / 2 : datos[n/2], unidad);

    // Reporte de Moda
    if (hay_moda == 0) printf("\nModa: No hay moda (Serie amodal)");
    else {
        printf("\nModa (%s): ", (conteo_modas > 1) ? "Multimodal" : "Unimodal");
        for (int i = 0; i < conteo_modas; i++) printf("%.2f ", modas_detectadas[i]);
        printf("%s (Frecuencia: %d)", unidad, max_frecuencia);
    }
    printf("\nRango: %.2f %s\n", datos[n - 1] - datos[0], unidad);
    
    /* --- REPRESENTACIÓN GRÁFICA: HISTOGRAMA DE FRECUENCIAS --- */
    printf("\n--- HISTOGRAMA DE FRECUENCIAS ---\n");
    int k = 9; // Aplicación de la Regla de Sturges para definición de intervalos
    float rango_h = datos[n-1] - datos[0];
    float amplitud = rango_h / k; // Determinación del ancho de clase
    int f_acumulada = 0;

    printf("--------------------------------------------------------------------------\n");
    printf("%-20s | %-10s | %-15s | %-12s\n", "Intervalo (Limites)", "Frec.", "F. Relativa", "F. Acum.");
    printf("--------------------------------------------------------------------------\n");

    for (int i = 0; i < k; i++) {
        float inferior = datos[0] + (i * amplitud);
        float superior = (i == k - 1) ? datos[n-1] + 1 : inferior + amplitud; 
        int f_directa = 0;

        // Conteo de frecuencias por intervalo de clase
        for (int j = 0; j < n; j++) {
            if (datos[j] >= inferior && datos[j] < superior) f_directa++;
        }

        f_acumulada += f_directa; // Cálculo de frecuencia absoluta acumulada
        float f_relativa = (float)f_directa / n; // Cálculo de peso porcentual (Frecuencia relativa)

        printf("[%7.2f - %7.2f) | %-10d | %-15.3f | %-12d ", inferior, superior, f_directa, f_relativa, f_acumulada);
        printf("\n");
    }
    printf("--------------------------------------------------------------------------\n");

    /* --- REPRESENTACIÓN GRÁFICA: DIAGRAMA DE TALLO Y HOJAS --- */
    printf("\n--- DIAGRAMA DE TALLO Y HOJAS ---\n");
    printf("-------------------------------------------------------------------------------------------------\n");
    // Formateo de columnas: Tallo (Centena), Hoja (Decena), Frecuencia Directa y Acumulada
    printf("%-10s | %-50s | %-10s | %-12s\n", "Tallo (C)", "Hojas (D)", "Frec.", "F. Acum.");
    printf("-------------------------------------------------------------------------------------------------\n");

    int tallo_actual = -1;
    int f_tallo = 0;
    int f_acum_tallo = 0;
    int contador_caracteres = 0;

    for (int i = 0; i < n; i++) {
        int tallo = (int)datos[i] / 100;
        int hoja = ((int)datos[i] % 100) / 10;

        // Detección de cambio de tallo para impresión de resumen de línea
        if (tallo != tallo_actual) {
            if (tallo_actual != -1) {
                // Relleno dinámico de espacios para garantizar alineación de columnas de frecuencia
                for (int s = contador_caracteres; s < 50; s++) printf(" ");
                f_acum_tallo += f_tallo;
                printf(" | %-10d | %-12d\n", f_tallo, f_acum_tallo);
            }
            printf("%-10d | ", tallo);
            tallo_actual = tallo;
            f_tallo = 0;
            contador_caracteres = 0;
        }
        printf("%d ", hoja);
        f_tallo++;
        contador_caracteres += 2; // Incremento de ancho basado en formato "%d "
    }

    // Finalización de la última categoría del diagrama
    for (int s = contador_caracteres; s < 50; s++) printf(" ");
    f_acum_tallo += f_tallo;
    printf(" | %-10d | %-12d\n", f_tallo, f_acum_tallo);
    printf("-------------------------------------------------------------------------------------------------\n");

    return 0;
}
